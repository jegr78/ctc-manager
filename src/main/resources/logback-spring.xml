<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Spring Boot defaults (CONSOLE_LOG_PATTERN, colors, etc.) -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Log directory: profile-dependent -->
    <springProfile name="docker | prod">
        <property name="LOG_DIR" value="/app/logs"/>
    </springProfile>
    <springProfile name="dev">
        <property name="LOG_DIR" value="data/dev/logs"/>
    </springProfile>
    <springProfile name="local">
        <property name="LOG_DIR" value="data/local/logs"/>
    </springProfile>
    <springProfile name="!docker &amp; !prod &amp; !dev &amp; !local">
        <property name="LOG_DIR" value="./logs"/>
    </springProfile>

    <!-- Console appender (Spring Boot default pattern) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- File appender with rolling policy -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/app.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Daily rotation with size-based split -->
            <fileNamePattern>${LOG_DIR}/archived/app.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <!-- Max file size before split within a day -->
            <maxFileSize>50MB</maxFileSize>
            <!-- Delete archives older than 7 days -->
            <maxHistory>7</maxHistory>
            <!-- Total size limit across all archived files -->
            <totalSizeCap>500MB</totalSizeCap>
            <!-- Clean up old archives on startup -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- Root Logger: Console + File -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
