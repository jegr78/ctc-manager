<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Spring Boot Defaults (CONSOLE_LOG_PATTERN, Farben, etc.) -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Log-Verzeichnis: profil-abhaengig -->
    <springProfile name="docker | prod">
        <property name="LOG_DIR" value="/app/logs"/>
    </springProfile>
    <springProfile name="dev">
        <property name="LOG_DIR" value="data/dev/logs"/>
    </springProfile>
    <springProfile name="local">
        <property name="LOG_DIR" value="data/local/logs"/>
    </springProfile>
    <springProfile name="!docker &amp; !prod &amp; !dev &amp; !local">
        <property name="LOG_DIR" value="./logs"/>
    </springProfile>

    <!-- T-93-01 + T-93-02 mitigation: %replace masks Discord webhook URLs
         (https://discord.com/api/webhooks/{id}/{token} → ***/***) in BOTH
         console and file appenders. Regex deliberately broadened from the
         discord.com anchor to https?://[^/\s]+/api/webhooks/[^/\s]+/[^/\s]+ so
         WireMock loopback URLs in DiscordLogMaskingIT are also masked. False-
         positive risk is low — no other system writes /api/webhooks/ paths.
         See .planning/phases/93-discord-foundation/93-THREAT-MODEL.md. -->

    <!-- Console Appender — webhook-URL-masking pattern -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %replace(%m%n%wEx){'https?://[^/\s]+/api/webhooks/[^/\s]+/[^/\s]+', 'https://***/api/webhooks/***/***'}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- File Appender mit Rolling Policy — webhook-URL-masking pattern -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/app.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%15.15t] %-40.40logger{39} : %replace(%m%n%wEx){'https?://[^/\s]+/api/webhooks/[^/\s]+/[^/\s]+', 'https://***/api/webhooks/***/***'}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Taegliche Rotation mit Groessen-Split -->
            <fileNamePattern>${LOG_DIR}/archived/app.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <!-- Max Groesse pro Datei bevor Split innerhalb eines Tages -->
            <maxFileSize>50MB</maxFileSize>
            <!-- Archive aelter als 7 Tage loeschen -->
            <maxHistory>7</maxHistory>
            <!-- Gesamtlimit ueber alle archivierten Dateien -->
            <totalSizeCap>500MB</totalSizeCap>
            <!-- Beim Start alte Archive aufraeumen -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- Root Logger: Console + File -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
