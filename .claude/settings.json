{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-pr-exists.sh",
            "if": "Bash(gh pr create*)",
            "timeout": 10,
            "statusMessage": "Checking for existing milestone PR..."
          }
        ]
      }
    ]
  }
}
