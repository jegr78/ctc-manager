# Produktions-Datenbank
DATABASE_URL=jdbc:mariadb://your-db-host:3306/ctcdb
DATABASE_USERNAME=ctc_prod
DATABASE_PASSWORD=changeme

# Admin credentials (prod)
CTC_ADMIN_USER=admin
CTC_ADMIN_PASSWORD=change-me-in-production

# Discord integration (v1.13)
# DISCORD_BOT_TOKEN is REQUIRED for any Discord operation in prod/local/docker
# profiles. Plain bot-token string (no "Bot " prefix — DiscordRestClient adds it).
# Never commit the literal token. Rotate via Discord Developer Portal if leaked.
DISCORD_BOT_TOKEN=

# Discord dev-profile auto-seed (v1.13 Plan 94-04)
# Active only on the `dev` profile (in-memory H2). On every dev boot, if the
# DiscordGlobalConfig row has no guildId yet, the DiscordDevSeeder populates the
# config + auto-assigns team Discord-role-IDs by matching role-name == team
# shortName. Lets you skip the manual /admin/discord-config form fill on every
# dev restart.
#
# Snowflakes are non-secret per Phase 93 D-01 and have committed defaults in
# application-dev.yml. Override here (or via shell env) only when you need
# different values than the committed defaults.
DISCORD_DEV_SEED_ENABLED=true
DISCORD_DEV_GUILD_ID=
DISCORD_DEV_BOT_APP_ID=
DISCORD_DEV_CURRENT_MATCH_CATEGORY=
DISCORD_DEV_RESULTS_FORUM=
DISCORD_DEV_STANDINGS_FORUM=
DISCORD_DEV_VS_EMOJI=

# Discord announcement webhook URL — SECRET (the token segment after the
# channel-id grants post permission per T-93-02). NEVER commit. Set as env-var
# only. Leave blank to skip seeding the webhook URL (you can still fill it via
# /admin/discord-config UI per session).
DISCORD_DEV_ANNOUNCEMENT_WEBHOOK_URL=
